datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Couple {
  id        String   @id @default(uuid())
  startDate DateTime? // The date when the couple started their relationship
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  score     Int      @default(0)

  users         User[]
  dates         DateEvent[]
  events        CalendarEvent[]
  wishlist      WishlistItem[]
  favoriteItems FavoriteItem[]
}

model User {
  telegramId String   @id // Telegram user ID (as a String to avoid BigInt JSON serialization issues)
  username   String?
  firstName  String
  photoUrl   String?
  coupleId   String
  couple     Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  wishlistItems WishlistItem[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DateEvent {
  id              String   @id @default(uuid())
  title           String
  description     String?
  location        String?
  dateTime        DateTime
  isCompleted     Boolean  @default(false)
  coupleId        String
  couple          Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById     String   // Telegram ID of the creator
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("pending") // "pending" | "accepted" | "declined"
  creatorFeedback String?
  creatorEmoji    String?
  partnerFeedback String?
  partnerEmoji    String?
  photoRelation   DateEventPhoto?
  feedbackNotified Boolean @default(false)
}

model CalendarEvent {
  id               String   @id @default(uuid())
  title            String
  description      String?
  date             DateTime // Date of the event
  lastNotifiedYear Int?     // Track when the couple was notified of this anniversary in a given year
  isRecurring      Boolean  @default(true)
  coupleId         String
  couple           Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById      String   // Telegram ID of the creator
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WishlistItem {
  id            String   @id @default(uuid())
  title         String
  url           String?
  price         String?
  type          String   @default("item") // "item" or "place"
  isPurchased   Boolean  @default(false)
  coupleId      String
  couple        Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById   String   // Telegram ID of the creator
  creator       User     @relation(fields: [createdById], references: [telegramId], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  description   String?
  photoRelation WishlistItemPhoto?
  creatorRating Int?     // 1-5 rating
  partnerRating Int?     // 1-5 rating
}

model FavoriteItem {
  id          String   @id @default(uuid())
  title       String
  category    String   // "movie" | "song" | "place" | "other"
  creatorNote String?
  partnerNote String?
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DateEventPhoto {
  id          String    @id @default(uuid())
  photo       String    // Base64 string
  dateEventId String    @unique
  dateEvent   DateEvent @relation(fields: [dateEventId], references: [id], onDelete: Cascade)
}

model WishlistItemPhoto {
  id             String       @id @default(uuid())
  photo          String       // Base64 string
  wishlistItemId String       @unique
  wishlistItem   WishlistItem @relation(fields: [wishlistItemId], references: [id], onDelete: Cascade)
}
